MIN_VALIDATION_CONFIDENCE=0.6
AUTO_FILTER_INVALID=true
RETRY_ON_VALIDATION_FAILURE=true
ENABLE_FEEDBACK_LEARNING=true

# 快速启动模式
FAST_START=false